          <NetworkSource><StructuredText xmlns="http://www.siemens.com/automation/Openness/SW/NetworkSource/StructuredText/v3">
  <LineComment Inserted="false" NoClosingBracket="false" UId="21">
    <Text UId="22"> --- Підготовка коеф. фільтра ---</Text>
  </LineComment>
  <NewLine Num="1" UId="23" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="24">
    <Text UId="25">rAlpha := rFilterSet;/</Text>
  </LineComment>
  <NewLine Num="1" UId="26" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="27">
    <Text UId="28">IF rAlpha &lt; 0.0 THEN</Text>
  </LineComment>
  <NewLine Num="1" UId="29" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="30">
    <Text UId="31">    rAlpha := 0.0;</Text>
  </LineComment>
  <NewLine Num="1" UId="32" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="33">
    <Text UId="34">END_IF;</Text>
  </LineComment>
  <NewLine Num="1" UId="35" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="36">
    <Text UId="37">IF rAlpha &gt; 1.0 THEN</Text>
  </LineComment>
  <NewLine Num="1" UId="38" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="39">
    <Text UId="40">    rAlpha := 1.0;</Text>
  </LineComment>
  <NewLine Num="1" UId="41" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="42">
    <Text UId="43">END_IF;</Text>
  </LineComment>
  <NewLine Num="2" UId="44" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="45">
    <Text UId="46"> --- Ініціалізація ---</Text>
  </LineComment>
  <NewLine Num="1" UId="47" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="48">
    <Text UId="49">IF xInit THEN</Text>
  </LineComment>
  <NewLine Num="1" UId="50" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="51">
    <Text UId="52">    rY := rScaledRaw;/</Text>
  </LineComment>
  <NewLine Num="1" UId="53" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="54">
    <Text UId="55">    xInit := FALSE;</Text>
  </LineComment>
  <NewLine Num="1" UId="56" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="57">
    <Text UId="58">END_IF;</Text>
  </LineComment>
  <NewLine Num="2" UId="59" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="60">
    <Text UId="61"> --- Фільтр: y = y + α*(x - y) ---</Text>
  </LineComment>
  <NewLine Num="1" UId="62" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="63">
    <Text UId="64">rY := rY + rAlpha * (rScaledRaw - rY);</Text>
  </LineComment>
  <NewLine Num="2" UId="65" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="66">
    <Text UId="67"> --- Вихід ---</Text>
  </LineComment>
  <NewLine Num="1" UId="68" />
  <LineComment Inserted="false" NoClosingBracket="false" UId="69">
    <Text UId="70">#rOutput := rY;</Text>
  </LineComment>
</StructuredText></NetworkSource>
