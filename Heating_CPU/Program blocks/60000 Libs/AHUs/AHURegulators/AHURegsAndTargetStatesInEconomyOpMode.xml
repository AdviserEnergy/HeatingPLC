              <Culture>en-US</Culture>
              <Text>Operation Modes                                                 Unit State
0                                                                              0=Stopped
1=Economy                                                           1=Checking-up  
                                                                                2=Preheating
                                                                                3=Starting 
                                                                                4=RecirculatingOperation (Protection)
                                                                                5=Sustained Mode (Economy)
                                                                                Not 6=Sustained Mode (PreComfort setpoints) 
                                                                                Not 7=Comfort  operation
                                                                                Not 8=Night Cooling
                                                                                9=Stopping
                                                                                10=Blocking
                                                                                11=FrostProtecting</Text>
